# Tendencys Desktop — environment configuration
# Copy to .env.local and adjust as needed

# Sentry crash/error reporting DSN. NOT a VITE_ var: it is baked into the Rust
# binary at compile time via option_env!("SENTRY_DSN"), so it must be present in
# the build process environment (a shell env var for `tauri:dev`, or the
# SENTRY_DSN GitHub Actions secret in CI) — putting it in a .env file alone does
# NOT reach the cargo build. Leave empty to disable Sentry entirely (local dev).
SENTRY_DSN=

# Accounts SSO base URL
# Sandbox (default): https://accounts-sandbox.envia.com
# Local Accounts (accountsdb): http://localhost:8080
# Production: https://accounts.envia.com
VITE_TENDENCYS_BASE_URL=https://accounts-sandbox.envia.com

# Shell site ID — Tendencys Desktop in accountsdb
# Redirects: tendencys://authentication + http://localhost:1420/authentication
VITE_SHELL_SITE_ID=6a51478d752f0077b7d9b356

# --- Per-service URLs + Accounts site IDs (sandbox / accountsdb) ---
# Shipping SSO callback lives on ship*.envia.com (NOT shipping.envia.com, which
# 404s /authentication). Prod: https://ship.envia.com — Staging: https://ship-stage.envia.com
VITE_ENVIA_SHIPPING_URL=https://ship-stage.envia.com
VITE_ENVIA_SHIPPING_SITE_ID=62f1259459ad8b9e8dc0b85c

VITE_ENVIA_CARGO_URL=https://cargo.envia.com
VITE_ENVIA_CARGO_SITE_ID=6938e32b8a76cd4f2508d2a2

VITE_ENVIA_FULFILLMENT_URL=https://fulfillment-test.envia.com
VITE_ENVIA_FULFILLMENT_SITE_ID=65315bd5d794a975c9941574

VITE_ENVIA_WMS_URL=https://wms.envia.com
VITE_ENVIA_WMS_SITE_ID=65315c26d794a975c9948c6f

# Sandbox: sandbox.ecartpay.com. Prod: https://app.ecart.com (must equal live
# product HOSTNAME — marketing ecartpay.com uses HOSTNAME=pay.ecart.com and
# fails Accounts aud-vs-Referer with "token is not valid").
VITE_ECART_PAY_URL=https://sandbox.ecartpay.com
VITE_ECART_PAY_SITE_ID=60b7f96f4118eb4370469d19

VITE_ECART_BANKING_URL=https://banking.ecart.com
VITE_ECART_BANKING_SITE_ID=699e00dccfd0922c0b0e50d6

# Must equal the ecartapi-dashboard deployment's API_BASE (https://app.ecartapi.com
# — the origin used for the handoff aud vs the Referer the dashboard sends to
# Accounts). Do not use marketing `ecartapi.com` — it 404s and fails aud-vs-Referer.
VITE_ECART_API_URL=https://app.ecartapi.com
VITE_ECART_API_SITE_ID=696695a6ae23f53b010f5b16

# Developer hub — public API docs (opened in the system browser)
VITE_ENVIA_DOCS_URL=https://docs.envia.com
VITE_ECART_API_DOCS_URL=https://docs.ecartapi.com
VITE_ENVIA_FULFILLMENT_DOCS_URL=https://api.fulfillment.envia.com/
VITE_ECART_PAY_DOCS_URL=https://docs.ecartpay.com
VITE_ENVIA_CARGO_DOCS_URL=https://api.cargo.envia.com/api/docs

# --- Accounts checklist ---
# Sandbox Desktop site (accountsdb): 6a51478d752f0077b7d9b356
#   redirects: tendencys://authentication, http://localhost:1420/authentication
# Shipping (Envia) site: 62f1259459ad8b9e8dc0b85c whitelists
#   https://ship.envia.com/authentication, https://ship-stage.envia.com/authentication,
#   https://ship-private.envia.com/authentication
# Prod ecartdb uses different site ObjectIds — swap env when targeting production.
