{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for Tendencys Desktop",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-hide",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:window:allow-unminimize",
    "deep-link:default",
    "opener:default",
    "store:default",
    "dialog:default",
    "updater:default",
    "process:default",
    "sentry:default",
    "allow-list-printers",
    "allow-save-bytes",
    "allow-print-test-page",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://accounts-sandbox.envia.com"
        },
        {
          "url": "https://accounts.envia.com"
        },
        {
          "url": "https://accounts.ecart.com"
        },
        {
          "url": "http://localhost:8080"
        }
      ]
    },
    "allow-validate-accounts-token",
    "allow-device-key",
    "allow-select-service",
    "allow-navigate-service",
    "allow-service-history-back",
    "allow-service-history-forward",
    "allow-reload-service",
    "allow-set-service-visible",
    "allow-set-content-left-inset",
    "allow-logout-webviews",
    "allow-seed-accounts-session",
    "allow-clear-accounts-session",
    "allow-read-accounts-session"
  ]
}
